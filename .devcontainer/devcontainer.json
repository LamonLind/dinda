{
    "name": "Debian Slim + KVM (manual setup)",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "mounts": [
        "source=/tmp,target=/var/lib/docker,type=bind,consistency=cached"
    ],
    "forwardPorts": [
        22,
        3389,
        5900,
        8006
    ],
    "portsAttributes": {
        "22": {
            "label": "GitHub Codespaces (SSH)",
            "onAutoForward": "notify"
        },
        "3389": {
            "label": "QEMU (RDP)",
            "onAutoForward": "notify"
        },
        "5900": {
            "label": "QEMU (VNC)",
            "onAutoForward": "notify"
        },
        "8006": {
            "label": "QEMU (HTTP/HTTPS)",
            "onAutoForward": "notify"
        }
    },
    "capAdd": [
        "ALL"
    ],
    "securityOpt": [
        "seccomp=unconfined"
    ],
    "runArgs": [
        "--device=/dev/kvm",
        "--device=/dev/net/tun",
        "--device=/dev/vhost-net"
    ],
    "privileged": true,
    "containerUser": "root",
    "remoteUser": "root",
    "containerEnv": {
        "VSCODE_AGENT_FOLDER": "/tmp/.vscode-server",
        "XDG_CACHE_HOME": "/tmp/.cache"
    },
    "remoteEnv": {
        "VSCODE_AGENT_FOLDER": "/tmp/.vscode-server",
        "XDG_CACHE_HOME": "/tmp/.cache"
    },
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/github,type=bind,consistency=cached",
    "workspaceFolder": "/workspaces/github"
}
